# --- Demo user (used when CRAMBLY_AUTH_DISABLED=true — local dev without JWT) ---
CRAMBLY_DEMO_USER_ID=00000000-0000-0000-0000-000000000001
CRAMBLY_DEMO_USER_EMAIL=demo@crambly.app
# Verify Supabase access tokens on the API. Set false for real login (needs SUPABASE_URL).
CRAMBLY_AUTH_DISABLED=true
# Legacy JWT secret (Dashboard → JWT Keys → Legacy): used only if tokens are still HS256.
# After JWT Signing Keys rotation, access tokens are ES256 — the API verifies those via JWKS at SUPABASE_URL/auth/v1/.well-known/jwks.json (SUPABASE_URL must match the project).
SUPABASE_JWT_SECRET=

# --- Google Gemini (LLM + embeddings) ---
GEMINI_API_KEY=
# LLM id — see https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-3.1-pro-preview
# If unavailable on your key, set GEMINI_MODEL to another id from the models doc above.
# Fast tier (text-only tasks: transforms, meme briefs, etc.). Defaults to Flash-Lite for higher RPM/latency.
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
# Heavy tier (multimodal ingestion: PDF/image/audio parsing). Defaults to Pro-Preview for accuracy.
GEMINI_INGESTION_MODEL=gemini-3.1-pro-preview
# Meme “AI Reimagine” / Imgflip fallback image model (REST image output).
GEMINI_MEME_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Optional — Imgflip caption API for instant classic templates (https://api.imgflip.com/)
IMGFLIP_USERNAME=
IMGFLIP_PASSWORD=
# Embeddings (text-embedding-004 retired Jan 2026). Default: 768-dim Matryoshka → fits pgvector(768).
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# Use 3072 only after running supabase/migrations/20250324000000_concepts_embedding_3072_optional.sql
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=768

# --- Supabase ---
# Required for FastAPI JWT verification when using asymmetric signing keys (must match NEXT_PUBLIC_SUPABASE_URL host).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Storage bucket for raw uploads (create in Supabase Dashboard)
SUPABASE_UPLOAD_BUCKET=uploads

# --- YouTube Data API v3 (study deck video suggestions) ---
YOUTUBE_API_KEY=

# --- ElevenLabs (TTS) ---
ELEVENLABS_API_KEY=
# Optional default voice ID from ElevenLabs dashboard
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Resend (email notifications: daily digest + exam reminders) ---
RESEND_API_KEY=
# Verified-domain from address once you add a domain; Resend demo: onboarding@resend.dev
RESEND_FROM_EMAIL=Crambly <onboarding@resend.dev>
# Links in emails (library / courses)
CRAMBLY_PUBLIC_WEB_URL=http://localhost:3000
# Fallback TTS when ElevenLabs fails (uses GEMINI_API_KEY; keep as fallback only — low quota)
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# --- Redis (optional — leave empty; Crambly runs fine without it) ---
REDIS_URL=
# If you ever run Redis locally: REDIS_URL=redis://localhost:6379/0

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Semester length in days for deadline urgency normalization
TOTAL_SEMESTER_DAYS=120
# CORS: comma-separated browser origins (no trailing slash). Include local dev + prod, e.g.:
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
# * = dev-only; cannot use with CORS_ALLOW_CREDENTIALS=true (server forces credentials off for *).
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
# Email digest/reminder scheduler (APScheduler in-process). Set false on extra API replicas.
ENABLE_NOTIFICATION_SCHEDULER=true

# --- Web (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
# Fallback user id when not signed in (must match backend demo user if AUTH_DISABLED)
NEXT_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-000000000001
# Server routes under /web (e.g. Focus Mode /api/explain-snippet) need GEMINI_API_KEY in the
# environment for `next dev` / `next start`. Copy from this file into web/.env.local if you run Next from /web.

# --- Mobile (Expo) — set in app.json extra or .env via expo-env ---
# Android emulator cannot reach host "localhost"; use http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# Copy this file to the repo root as `.env` for local dev. Backend also reads `../.env`
# when launched from the /backend folder.
